            10.0);
        float morph_coupler_wave =
            0.5 + 0.5 * sin(morph_coupler_phase);
        float morph_coupler_focus =
            1.0 - smoothstep(
                0.0,
                0.30,
                abs(morph_coupler_wave - 0.60));
        float morph_coupler_span =
            (0.90
