             + 1.4 * spectral_dispersion
             + 1.8 * abs(bridge_shear) * bridge_band)
            * content_scale;
        float2 wake_lead_uv = clamp(
            in.screen_uv
                + refraction_uv * 0.34
                + bridge_dir
                    * texel
                    * wake_span
                    * (0.34 + 0.22 * wake_flow),
            float2(0.0),
            float2(1.0));
        float2 wake_trail_uv = clamp(
            in.screen_uv
                + refraction_uv * 0.24
                - bridge_dir
