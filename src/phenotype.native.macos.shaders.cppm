            backdrop_rgb = mix(
                backdrop_rgb,
                mix(backdrop_rgb, pocket_tint, 0.22 + 0.16 * pocket_detail),
                pocket_weight);
            backdrop_rgb += pocket_tint
                * pocket_weight
                * (0.010
                   + 0.020 * dynamic_light_highlight
