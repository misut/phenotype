                    0.44,
                    length(flow_upstream_rgb - flow_downstream_rgb)),
            0.0,
            1.0);
        float3 flow_neutral = mix(
            flow_transport,
            float3(flow_luma),
            flow_depth * (0.12 + 0.14 * glass_shadow_gain)
                + flow_coherence * 0.12);
        float3 flow_layer = mix(
            flow_neutral,
            flow_shear,
            0.18
                + 0.16 * flow_pickup
                + 0.14 * flow_lobe
                + 0.12 * flow_curvature
                + 0.10 * flow_light_face);
        flow_layer = clamp(
            (flow_layer - float3(0.50))
                    * (1.0
                       + clear_glass_contrast * 0.012
