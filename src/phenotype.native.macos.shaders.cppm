        float diffusion_surface_luma =
            dot(rgb, float3(0.2126, 0.7152, 0.0722));
        float diffusion_dark = smoothstep(
            0.06,
            0.32,
            diffusion_surface_luma - diffusion_luma);
        float diffusion_light = smoothstep(
