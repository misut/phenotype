        0.0,
        0.12);
    if (chromatic_polish_strength > 0.0001) {
        float polish_center =
            1.0 - smoothstep(0.18, 1.14, normalized_len);
        float polish_rim = edge_lens
            * (0.32
               + 0.68
                   * (1.0 - smoothstep(
                       0.0,
                       max(edge_bevel_width * 1.58, 0.5),
