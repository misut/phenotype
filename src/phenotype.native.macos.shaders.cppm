                    * wake_cross_span
                    * bridge_shear
                    * (0.44 + 0.22 * wake_flow),
            float2(0.0),
            float2(1.0));
        float3 wake_lead =
            backdrop.sample(samp, wake_lead_uv).rgb;
        float3 wake_trail =
            backdrop.sample(samp, wake_trail_uv).rgb;
        float3 wake_cross_rgb =
