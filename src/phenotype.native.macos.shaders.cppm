                    * (1.0
                       + clear_glass_contrast * 0.012
                       + morph_coupler_fresnel * 0.010
                       + morph_coupler_bright * 0.008
                       - glass_shadow_gain * 0.004)
                + float3(0.50),
            0.0,
            1.0);
        morph_coupler_layer += morph_coupler_tint
            * morph_coupler_fresnel
            * (0.0010
