            1.0);
        float morph_coupler_gate = clamp(
            morph_coupler_center * 0.18
                + morph_coupler_edge * 0.22
                + morph_coupler_bridge * 0.26
                + morph_coupler_transition * group_blend_strength * 0.24
                + edge_lens * 0.10,
            0.0,
            1.0);
        float2 morph_coupler_viewport_size = max(
            float2(
                in.screen_uv.x > 0.0001
                    ? in.screen_pos.x / in.screen_uv.x
                    : float(backdrop.get_width()) / content_scale,
                in.screen_uv.y > 0.0001
                    ? in.screen_pos.y / in.screen_uv.y
                    : float(backdrop.get_height()) / content_scale),
            float2(1.0));
        float2 morph_coupler_group_center_screen =
            in.group_rect.xy + morph_coupler_group_size * 0.5;
        float2 morph_coupler_group_center_uv = clamp(
            morph_coupler_group_center_screen / morph_coupler_viewport_size,
            float2(0.0),
            float2(1.0));
        float2 morph_coupler_to_center =
            morph_coupler_group_center_uv - in.screen_uv;
        float morph_coupler_center_distance =
            length(morph_coupler_to_center);
        float2 morph_coupler_center_dir =
            morph_coupler_center_distance > 0.0001
                ? morph_coupler_to_center / morph_coupler_center_distance
                : refraction_dir;
        float2 morph_coupler_axis_raw =
            bridge_dir * (0.34 + 0.24 * morph_coupler_bridge)
            + refraction_dir * (0.26 + 0.18 * clear_glass_detail)
            + morph_coupler_center_dir
