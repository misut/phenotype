            1.0 - smoothstep(0.16, 1.20, normalized_len);
        float depth_rim = edge_lens
            * (0.30
               + 0.70
                   * (1.0 - smoothstep(
                       0.0,
                       max(edge_bevel_width * 1.40, 0.5),
                       signed_edge_distance)));
