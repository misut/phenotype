                + morph_coupler_alignment * 0.20
                + morph_coupler_transition * 0.16
                + morph_coupler_bridge * 0.14,
            0.0,
            1.0);
        float3 morph_coupler_tint = mix(
            float3(1.0),
            float3(
                spectral_warmth,
                0.14 * (spectral_warmth + spectral_coolness),
                spectral_coolness),
            clamp(0.18 + 0.42 * spectral_rim_tint, 0.0, 1.0));
        float3 morph_coupler_neutral = mix(
            morph_coupler_probe,
            float3(morph_coupler_luma),
