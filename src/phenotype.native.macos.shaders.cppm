                ? morph_coupler_axis_raw / morph_coupler_axis_len
                : refraction_dir;
        float2 morph_coupler_cross =
            float2(-morph_coupler_axis.y, morph_coupler_axis.x);
        float morph_coupler_alignment =
            smoothstep(-0.30, 0.90, dot(morph_coupler_axis, bridge_dir));
        float morph_coupler_phase = clamp(
            dot(morph_coupler_group_norm, morph_coupler_axis)
                    * (5.0 + 2.6 * morph_coupler_transition)
                + dot(morph_coupler_group_norm, morph_coupler_cross)
                    * (2.3 + 1.6 * morph_coupler_bridge)
                + bridge_axial * (3.4 + 2.2 * morph_coupler_bridge)
                + bridge_shear * morph_coupler_bridge * 2.0
