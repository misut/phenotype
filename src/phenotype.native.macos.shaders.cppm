            float2(1.0));
        float3 polish_warm =
            backdrop.sample(samp, polish_warm_uv).rgb;
        float3 polish_cool =
            backdrop.sample(samp, polish_cool_uv).rgb;
        float3 polish_anchor =
            backdrop.sample(samp, polish_anchor_uv).rgb;
        float3 polish_split =
            float3(polish_warm.r,
