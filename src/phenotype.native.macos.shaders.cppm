        float3 pressure_lateral =
            backdrop.sample(samp, pressure_lateral_uv).rgb;
        float3 pressure_rgb =
            pressure_focus * 0.48
            + pressure_ring * 0.30
            + pressure_lateral * 0.22;
        float pressure_luma =
