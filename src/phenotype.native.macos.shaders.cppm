                + float3(0.50),
            0.0,
            1.0);
        interlayer_layer *= float3(1.0)
            + in.tint.rgb
                * (0.010
                   + 0.020 * tint_chroma * prominent_intensity);
        float3 interlayer_prism = float3(
            spectral_warmth + tint_chroma * in.tint.r * 0.10,
            0.12 * (spectral_warmth + spectral_coolness)
