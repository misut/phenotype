        float morph_coupler_bright = smoothstep(
            morph_coupler_surface_luma - 0.07,
            morph_coupler_surface_luma + 0.28,
            morph_coupler_luma);
        float morph_coupler_dark = smoothstep(
            0.08,
            0.34,
            morph_coupler_surface_luma - morph_coupler_luma);
        float morph_coupler_fresnel = clamp(
            morph_coupler_focus * 0.28
