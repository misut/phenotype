                + 0.14 * interlayer_lobe
                + 0.12 * interlayer_light_face
                + 0.10 * interlayer_relay_pickup);
        interlayer_layer = clamp(
            (interlayer_layer - float3(0.50))
                    * (1.0
                       + clear_glass_contrast * 0.012
                       + interlayer_lift * 0.010
                       + interlayer_relief * 0.012
