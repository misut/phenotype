                0.86,
                abs(dot(catch_normal, -dynamic_light_dir)));
        float catch_bridge_alignment =
            smoothstep(-0.28, 0.88, abs(dot(catch_tangent, bridge_dir)));
        float catch_gate = clamp(
            catch_rim_band
                * (0.34
