        float morph_shear_sign = bridge_shear >= 0.0 ? 1.0 : -1.0;
        float2 morph_forward_uv = clamp(
            in.screen_uv
                + refraction_uv * 0.58
                + bridge_dir
                    * texel
                    * morph_span
                    * (0.54 + 0.30 * morph_wave),
            float2(0.0),
            float2(1.0));
        float2 morph_return_uv = clamp(
            in.screen_uv
                + refraction_uv * 0.30
