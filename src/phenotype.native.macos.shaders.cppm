            float2(1.0));
        float2 pressure_lateral_uv = clamp(
            in.screen_uv
                + refraction_uv * 0.30
                + pressure_tangent
                    * texel
                    * pressure_span
                    * (0.50 + 0.34 * abs(pressure_shear))
                    * (pressure_shear >= 0.0 ? 1.0 : -1.0),
