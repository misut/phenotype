            1.0);
        parallax_layer = mix(
            parallax_layer,
            parallax_layer
                * (float3(1.0)
                   + in.tint.rgb
                       * (0.018
                          + 0.030 * tint_chroma * prominent_intensity)),
            tint_chroma * (0.10 + 0.10 * parallax_motion));
