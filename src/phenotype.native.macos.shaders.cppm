            0.0,
            1.0)
            * (0.48 + 0.52 * edge_lens);
        float coherence_surface =
            (1.0 - smoothstep(0.18, 1.18, normalized_len))
            * (0.38 + 0.62 * coherence_outer);
        float coherence_contact = clamp(
            pointer_lens * pointer_lens_strength
                + bridge_band * (0.38 + 0.62 * bridge_core)
