            float2(0.0),
            float2(1.0));
        float3 seal_under_rgb =
            backdrop.sample(samp, seal_under_uv).rgb;
        float3 seal_inner_rgb =
            backdrop.sample(samp, seal_inner_uv).rgb;
        float3 seal_lateral_rgb =
