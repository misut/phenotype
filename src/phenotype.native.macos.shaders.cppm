        echo_tint += float3(
            spectral_warmth,
            0.12 * (spectral_warmth + spectral_coolness),
            spectral_coolness)
            * (echo_wave * 0.30 + echo_shoulder * 0.28)
            * (0.10 + 0.30 * spectral_rim_tint);
