                0.30,
                horizon_surface_luma - horizon_luma);
        float3 horizon_neutral = mix(
            horizon_probe,
            float3(horizon_luma),
            0.28 + 0.20 * (1.0 - horizon_range));
        float3 horizon_layer = mix(
