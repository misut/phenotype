            dot(caustic_group_norm, caustic_axis)
                    * (5.8 + 2.8 * caustic_transition)
                + dot(caustic_group_norm, caustic_cross)
                    * (3.0 + 1.8 * caustic_bridge)
                + bridge_axial * (3.2 + 2.4 * caustic_bridge)
                + bridge_shear * caustic_bridge * 2.2
