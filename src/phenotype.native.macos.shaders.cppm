                max(edge_bevel_width * 3.0, 1.0),
                signed_edge_distance);
        float pressure_bridge =
            bridge_band * (0.30 + 0.70 * bridge_core);
        float pressure_transition = clamp(
            group_surface_execution * group_blend_strength * 0.28
                + shared_backdrop_scope * group_blend_strength * 0.22
                + union_execution * group_blend_strength * 0.20
                + morph_execution * group_blend_strength * 0.18
                + shape_blend_execution * group_blend_strength * 0.14
                + pressure_bridge * 0.20,
            0.0,
            1.0);
        float2 pressure_axis_raw =
            pressure_center_dir * (0.34 + 0.28 * pressure_transition)
            + bridge_dir * (0.26 + 0.24 * pressure_bridge)
            + refraction_dir * (0.22 + 0.14 * glass_lensing_gain)
            - dynamic_light_dir
                * (0.20 + 0.16 * dynamic_light_highlight)
            + dispersion_tangent
                * (0.12
                   + 0.10 * spectral_dispersion
                   + 0.08 * glass_dispersion_tangential);
        float pressure_axis_len = length(pressure_axis_raw);
        float2 pressure_axis =
            pressure_axis_len > 0.0001
                ? pressure_axis_raw / pressure_axis_len
                : pressure_center_dir;
        float2 pressure_cross =
            float2(-pressure_axis.y, pressure_axis.x);
        float pressure_light_face =
            smoothstep(-0.22, 0.92, dot(pressure_axis, -dynamic_light_dir));
        float pressure_bridge_alignment =
            smoothstep(-0.24, 0.88, abs(dot(pressure_axis, bridge_dir)));
        float pressure_phase = clamp(
            dot(pressure_group_norm, pressure_axis)
                    * (4.0 + 1.7 * pressure_transition)
                + dot(pressure_group_norm, pressure_cross)
                    * (2.8 + 1.2 * pressure_bridge)
                + dot(normalized_local, pressure_axis)
                    * (2.4 + 1.1 * pressure_local_center)
                + bridge_axial * (2.6 + 1.4 * bridge_core)
                + bridge_shear * bridge_band * 2.0
                + spectral_dispersion * 4.4,
            -12.0,
            12.0);
        float pressure_wave = 0.5 + 0.5 * sin(pressure_phase);
        float pressure_counter = 0.5 + 0.5 * cos(
            pressure_phase * 0.68
            + glass_caustic_spread * 4.0
            + materialize_rim_position * materialize_wave_strength * 2.0);
        float pressure_lobe =
            1.0 - smoothstep(0.0, 0.34, abs(pressure_wave - 0.54));
        float pressure_return_lobe =
            1.0 - smoothstep(0.0, 0.36, abs(pressure_counter - 0.52));
        float pressure_presence = clamp(
            pressure_group_center * 0.20
                + pressure_local_center * 0.12
                + pressure_edge * 0.18
                + pressure_bridge * 0.20
                + pressure_transition * 0.22
                + pressure_lobe * 0.10
                + group_blend_strength * 0.12,
            0.0,
            1.0);
        float pressure_span =
            (0.92
             + 1.9 * glass_thickness
             + 1.6 * clear_glass_detail
             + 1.4 * pressure_presence
             + 0.040 * blur_points)
            * content_scale
            * (0.86 + 0.14 * glass_lensing_gain);
        float pressure_cross_span =
            (0.62
             + 1.2 * glass_dispersion_tangential
             + 1.1 * spectral_dispersion
             + 0.9 * pressure_bridge_alignment)
            * content_scale;
        float pressure_center_pull = clamp(
            0.12
                + 0.24 * group_blend_strength
                + 0.20 * shared_backdrop_scope
                + 0.18 * pressure_transition
                + 0.16 * pressure_bridge,
            0.0,
            0.56);
        float2 pressure_base_uv = clamp(
            mix(in.screen_uv, pressure_group_center_uv, pressure_center_pull)
                + refraction_uv * (0.10 + 0.06 * pressure_transition),
            float2(0.0),
            float2(1.0));
        float2 pressure_forward_uv = clamp(
            pressure_base_uv
                + pressure_axis
                    * texel
                    * pressure_span
                    * (0.28 + 0.14 * pressure_lobe)
                + bridge_dir
                    * texel
                    * pressure_span
                    * pressure_bridge
                    * 0.16,
            float2(0.0),
            float2(1.0));
        float2 pressure_return_uv = clamp(
            pressure_base_uv
                - pressure_axis
                    * texel
                    * pressure_span
                    * (0.26 + 0.14 * pressure_return_lobe)
                - bridge_dir
                    * texel
                    * pressure_span
                    * pressure_bridge
                    * 0.12,
            float2(0.0),
            float2(1.0));
        float2 pressure_cross_a_uv = clamp(
            pressure_base_uv
                + pressure_cross
                    * texel
                    * pressure_cross_span
                    * (0.30 + 0.12 * pressure_wave)
                + dispersion_tangent
                    * texel
                    * pressure_span
                    * (0.08 + 0.08 * spectral_rim_tint),
            float2(0.0),
            float2(1.0));
        float2 pressure_cross_b_uv = clamp(
            pressure_base_uv
                - pressure_cross
                    * texel
                    * pressure_cross_span
                    * (0.28 + 0.12 * pressure_lobe)
                - dispersion_tangent
                    * texel
                    * pressure_span
                    * (0.08 + 0.08 * spectral_rim_tint),
            float2(0.0),
            float2(1.0));
        float2 pressure_light_uv = clamp(
            pressure_base_uv
                - dynamic_light_dir
                    * texel
                    * pressure_span
                    * (0.16 + 0.12 * pressure_light_face),
            float2(0.0),
            float2(1.0));
        float3 pressure_base_rgb =
            backdrop.sample(samp, pressure_base_uv).rgb;
        float3 pressure_forward_rgb =
            backdrop.sample(samp, pressure_forward_uv).rgb;
        float3 pressure_return_rgb =
            backdrop.sample(samp, pressure_return_uv).rgb;
        float3 pressure_cross_a_rgb =
            backdrop.sample(samp, pressure_cross_a_uv).rgb;
        float3 pressure_cross_b_rgb =
            backdrop.sample(samp, pressure_cross_b_uv).rgb;
        float3 pressure_light_rgb =
            backdrop.sample(samp, pressure_light_uv).rgb;
        float3 pressure_membrane_rgb =
            pressure_base_rgb * 0.24
            + pressure_forward_rgb * 0.18
            + pressure_return_rgb * 0.18
            + pressure_cross_a_rgb * 0.14
            + pressure_cross_b_rgb * 0.14
            + pressure_light_rgb * 0.12;
        float3 pressure_split = float3(
            pressure_forward_rgb.r,
            (pressure_base_rgb.g + pressure_light_rgb.g) * 0.5,
            pressure_return_rgb.b);
        float pressure_luma =
            dot(pressure_membrane_rgb, float3(0.2126, 0.7152, 0.0722));
        float pressure_surface_luma =
            dot(rgb, float3(0.2126, 0.7152, 0.0722));
        float pressure_chroma = max(
            max(abs(pressure_membrane_rgb.r - pressure_membrane_rgb.g),
                abs(pressure_membrane_rgb.g - pressure_membrane_rgb.b)),
            abs(pressure_membrane_rgb.b - pressure_membrane_rgb.r));
        float pressure_pickup =
            smoothstep(0.030, 0.34, pressure_chroma);
        float pressure_range = clamp(
            length(pressure_forward_rgb - pressure_return_rgb) * 0.24
                + length(pressure_cross_a_rgb - pressure_cross_b_rgb) * 0.22
                + length(pressure_light_rgb - pressure_base_rgb) * 0.16
                + abs(pressure_luma - pressure_surface_luma) * 0.18
                + pressure_lobe * 0.10
                + pressure_presence * 0.10,
            0.0,
            1.0);
        float pressure_coherence =
            1.0 - smoothstep(0.08, 0.38, pressure_range);
        float pressure_lift = smoothstep(
            pressure_surface_luma - 0.06,
            pressure_surface_luma + 0.30,
            pressure_luma);
        float pressure_depth = smoothstep(
            0.08,
            0.34,
            pressure_surface_luma - pressure_luma);
        float3 pressure_neutral = mix(
            pressure_membrane_rgb,
            float3(pressure_luma),
            pressure_depth * (0.12 + 0.14 * glass_shadow_gain)
                + pressure_coherence * 0.12);
        float3 pressure_layer = mix(
            pressure_neutral,
            pressure_split,
            0.16
                + 0.16 * pressure_pickup
                + 0.14 * pressure_lobe
                + 0.12 * pressure_presence
                + 0.10 * pressure_light_face);
        pressure_layer = clamp(
            (pressure_layer - float3(0.50))
                    * (1.0
                       + clear_glass_contrast * 0.012
                       + pressure_lift * 0.010
                       + pressure_transition * 0.010
                       - pressure_depth * 0.016)
                + float3(0.50),
            0.0,
            1.0);
        pressure_layer *= float3(1.0)
            + in.tint.rgb
                * (0.012
                   + 0.026 * tint_chroma * prominent_intensity);
        float3 pressure_prism = float3(
            spectral_warmth,
            0.13 * (spectral_warmth + spectral_coolness),
            spectral_coolness);
        pressure_layer += pressure_prism
            * pressure_pickup
            * (0.0008
               + 0.0026 * spectral_rim_tint
               + 0.0022 * glass_prismatic_gain
               + 0.0018 * glass_scattering_gain)
            * (0.32
               + 0.22 * pressure_light_face
               + 0.20 * pressure_lobe
               + 0.18 * pressure_presence
               + 0.14 * pressure_coherence);
        float pressure_gate = clamp(
            pressure_presence * 0.28
                + pressure_transition * 0.22
                + pressure_bridge * 0.18
                + pressure_lobe * 0.14
                + pressure_light_face * 0.10
                + pressure_coherence * 0.10,
            0.0,
            1.0);
        float pressure_weight =
            container_pressure_field_strength
            * pressure_gate
            * (0.30
               + 0.20 * pressure_coherence
               + 0.16 * pressure_pickup
               + 0.14 * pressure_lift
               + 0.12 * pressure_bridge_alignment
               + 0.10 * pressure_presence);
        rgb = mix(
            rgb,
            mix(
                rgb,
                pressure_layer,
                0.06
                    + 0.12 * pressure_lobe
                    + 0.10 * pressure_transition
                    + 0.08 * pressure_pickup),
            pressure_weight * 0.24);
        rgb += pressure_prism
            * pressure_weight
            * max(pressure_lobe, pressure_return_lobe * 0.72)
            * (0.0006
               + 0.0020 * dynamic_light_highlight
               + 0.0018 * glass_scattering_gain);
        float pressure_shadow =
            pressure_depth
            * pressure_weight
            * (0.0022 + 0.0070 * glass_shadow_gain)
            * (0.52 + 0.48 * (1.0 - pressure_light_face));
        rgb *= 1.0 - clamp(pressure_shadow, 0.0, 0.022);
        rgb = clamp(rgb, 0.0, 1.0);
    }
    float interactive_tint_gate = clamp(
        tint_strength * (0.54 + 0.46 * tint_chroma),
        0.0,
        1.0);
    float interactive_tint_field_strength = clamp(
        interactive_tint_gate
            * (0.018
               + 0.012 * prominent_intensity
               + 0.010 * clear_glass_detail
               + 0.010 * glass_scattering_gain
               + 0.008 * glass_prismatic_gain
               + 0.16 * container_pressure_field_strength
               + 0.14 * foreground_sheen_field_strength
               + 0.12 * interactive_kinetic_field_strength
               + 0.10 * container_cohesion_field_strength
               + 0.08 * lensing_flow_field_strength),
        0.0,
        0.052);
    if (interactive_tint_field_strength > 0.0001) {
        float tint_center =
            1.0 - smoothstep(0.22, 1.12, normalized_len);
        float tint_edge =
            1.0 - smoothstep(
                0.0,
                max(edge_bevel_width * 2.80, 1.0),
                signed_edge_distance);
        float tint_bridge =
            bridge_band * (0.32 + 0.68 * bridge_core);
        float tint_pointer =
            pointer_lens_raw * pointer_lens_strength;
        float tint_interaction = clamp(
            tint_center * 0.18
                + tint_edge * 0.18
                + tint_bridge * 0.18
                + tint_pointer * 0.20
                + group_blend_strength * 0.14
                + prominent_intensity * 0.12
                + container_pressure_field_strength * 2.4,
            0.0,
            1.0);
        float2 tint_axis_raw =
            -dynamic_light_dir * (0.34 + 0.20 * dynamic_light_highlight)
            + pointer_dir * (0.26 + 0.22 * tint_pointer)
            + bridge_dir * (0.22 + 0.20 * tint_bridge)
            + refraction_dir * (0.20 + 0.16 * glass_lensing_gain)
            + dispersion_tangent
                * (0.14
                   + 0.10 * spectral_dispersion
                   + 0.08 * glass_dispersion_tangential);
        float tint_axis_len = length(tint_axis_raw);
        float2 tint_axis =
            tint_axis_len > 0.0001
                ? tint_axis_raw / tint_axis_len
                : -dynamic_light_dir;
        float2 tint_cross = float2(-tint_axis.y, tint_axis.x);
        float tint_light_face =
            smoothstep(-0.20, 0.94, dot(tint_axis, -dynamic_light_dir));
        float tint_bridge_alignment =
            smoothstep(-0.24, 0.88, abs(dot(tint_axis, bridge_dir)));
        float tint_phase = clamp(
            dot(normalized_local, tint_axis)
                    * (4.4 + 1.8 * tint_interaction)
                + dot(normalized_local, tint_cross)
                    * (2.8 + 1.2 * tint_bridge)
                + bridge_axial * (2.2 + 1.3 * bridge_core)
                + bridge_shear * bridge_band * 1.8
                + spectral_dispersion * 4.6,
            -12.0,
            12.0);
        float tint_wave = 0.5 + 0.5 * sin(tint_phase);
        float tint_counter =
            0.5 + 0.5 * cos(tint_phase * 0.72 + glass_caustic_spread * 4.0);
        float tint_lobe =
            1.0 - smoothstep(0.0, 0.34, abs(tint_wave - 0.55));
        float tint_return_lobe =
            1.0 - smoothstep(0.0, 0.36, abs(tint_counter - 0.52));
        float tint_span =
            (0.84
             + 1.7 * glass_thickness
             + 1.4 * clear_glass_detail
             + 1.3 * tint_interaction
             + 0.036 * blur_points)
            * content_scale
            * (0.88 + 0.12 * glass_lensing_gain);
        float tint_cross_span =
            (0.56
             + 1.1 * spectral_dispersion
             + 1.0 * glass_dispersion_tangential
             + 0.8 * tint_bridge_alignment)
            * content_scale;
        float2 tint_center_uv = clamp(
            in.screen_uv
                + refraction_uv * (0.08 + 0.04 * tint_interaction),
            float2(0.0),
            float2(1.0));
        float2 tint_light_uv = clamp(
            in.screen_uv
                - dynamic_light_dir
                    * texel
                    * tint_span
                    * (0.20 + 0.12 * tint_light_face)
                + tint_axis
                    * texel
                    * tint_span
                    * (0.12 + 0.10 * tint_lobe),
            float2(0.0),
            float2(1.0));
        float2 tint_shadow_uv = clamp(
            in.screen_uv
                + dynamic_light_dir
                    * texel
                    * tint_span
                    * (0.18 + 0.12 * (1.0 - tint_light_face))
                - tint_axis
                    * texel
                    * tint_span
                    * (0.10 + 0.08 * tint_return_lobe),
            float2(0.0),
            float2(1.0));
        float2 tint_cross_a_uv = clamp(
            in.screen_uv
                + tint_cross
                    * texel
                    * tint_cross_span
                    * (0.28 + 0.12 * tint_wave)
                + dispersion_tangent
                    * texel
                    * tint_span
                    * (0.08 + 0.08 * spectral_rim_tint),
            float2(0.0),
            float2(1.0));
        float2 tint_cross_b_uv = clamp(
            in.screen_uv
                - tint_cross
                    * texel
                    * tint_cross_span
                    * (0.26 + 0.12 * tint_lobe)
                - dispersion_tangent
                    * texel
                    * tint_span
                    * (0.08 + 0.08 * spectral_rim_tint),
            float2(0.0),
            float2(1.0));
        float3 tint_center_rgb =
            backdrop.sample(samp, tint_center_uv).rgb;
        float3 tint_light_rgb =
            backdrop.sample(samp, tint_light_uv).rgb;
        float3 tint_shadow_rgb =
            backdrop.sample(samp, tint_shadow_uv).rgb;
        float3 tint_cross_a_rgb =
            backdrop.sample(samp, tint_cross_a_uv).rgb;
        float3 tint_cross_b_rgb =
            backdrop.sample(samp, tint_cross_b_uv).rgb;
        float3 tint_backdrop_rgb =
            tint_center_rgb * 0.28
            + tint_light_rgb * 0.22
            + tint_shadow_rgb * 0.18
            + tint_cross_a_rgb * 0.16
            + tint_cross_b_rgb * 0.16;
        float3 tint_rgb = clamp(in.tint.rgb, 0.0, 1.0);
        float tint_backdrop_luma =
            dot(tint_backdrop_rgb, float3(0.2126, 0.7152, 0.0722));
        float tint_surface_luma =
            dot(rgb, float3(0.2126, 0.7152, 0.0722));
        float tint_color_luma =
            dot(tint_rgb, float3(0.2126, 0.7152, 0.0722));
        float tint_backdrop_range = clamp(
            length(tint_light_rgb - tint_shadow_rgb) * 0.24
                + length(tint_cross_a_rgb - tint_cross_b_rgb) * 0.22
                + abs(tint_backdrop_luma - tint_surface_luma) * 0.18
                + tint_lobe * 0.10
                + tint_interaction * 0.10,
            0.0,
            1.0);
        float tint_coherence =
            1.0 - smoothstep(0.08, 0.38, tint_backdrop_range);
        float tint_lift = smoothstep(
            tint_surface_luma - 0.06,
            tint_surface_luma + 0.30,
            tint_backdrop_luma);
        float tint_depth = smoothstep(
            0.08,
            0.34,
            tint_surface_luma - tint_backdrop_luma);
        float3 tint_neutral = mix(
            tint_backdrop_rgb,
            float3(tint_backdrop_luma),
            tint_depth * (0.10 + 0.12 * glass_shadow_gain)
                + tint_coherence * 0.10);
        float3 tint_colored = mix(
            tint_neutral,
            mix(tint_rgb, tint_backdrop_rgb * (float3(1.0) + tint_rgb * 0.32),
                0.34 + 0.24 * tint_coherence),
            0.20
                + 0.26 * tint_chroma
                + 0.18 * tint_interaction
                + 0.12 * tint_lobe);
        tint_colored = clamp(
            (tint_colored - float3(0.50))
                    * (1.0
                       + clear_glass_contrast * 0.012
                       + tint_lift * 0.010
                       + tint_interaction * 0.010
                       - tint_depth * 0.014)
                + float3(0.50),
            0.0,
            1.0);
        float tint_complement_bias = clamp(
            abs(tint_color_luma - tint_backdrop_luma)
                + tint_chroma * 0.40,
            0.0,
            1.0);
        float3 tint_prism = float3(
            spectral_warmth + tint_rgb.r * 0.18,
            0.12 * (spectral_warmth + spectral_coolness)
                + tint_rgb.g * 0.10,
            spectral_coolness + tint_rgb.b * 0.18);
        tint_colored += tint_prism
            * (0.0006
               + 0.0024 * spectral_rim_tint
               + 0.0020 * glass_prismatic_gain
               + 0.0018 * glass_scattering_gain)
            * (0.30
               + 0.22 * tint_light_face
               + 0.20 * tint_lobe
               + 0.18 * tint_interaction
               + 0.12 * tint_complement_bias);
        float tint_gate = clamp(
            tint_interaction * 0.28
                + tint_lobe * 0.20
                + tint_bridge * 0.16
                + tint_pointer * 0.16
                + tint_light_face * 0.10
                + tint_coherence * 0.10,
            0.0,
            1.0);
        float tint_weight =
            interactive_tint_field_strength
            * tint_gate
            * (0.30
               + 0.22 * tint_chroma
               + 0.18 * tint_lift
               + 0.14 * tint_coherence
               + 0.12 * tint_bridge_alignment
               + 0.10 * tint_complement_bias);
        rgb = mix(
            rgb,
            tint_colored,
            tint_weight
                * (0.18
                   + 0.14 * tint_lobe
                   + 0.10 * tint_interaction));
        rgb += tint_prism
            * tint_weight
            * max(tint_lobe, tint_return_lobe * 0.72)
            * (0.0005
               + 0.0018 * dynamic_light_highlight
               + 0.0014 * glass_scattering_gain);
        float tint_shadow =
            tint_depth
            * tint_weight
            * (0.0018 + 0.0055 * glass_shadow_gain)
            * (0.50 + 0.50 * (1.0 - tint_light_face));
        rgb *= 1.0 - clamp(tint_shadow, 0.0, 0.018);
        rgb = clamp(rgb, 0.0, 1.0);
    }
    float edge_meniscus_field_strength = clamp(
        0.012 * refraction_edge_caustic
            + 0.010 * edge_chromatic_fringe
            + 0.010 * glass_caustic_spread
            + 0.008 * (glass_lensing_gain - 1.0)
            + 0.008 * spectral_rim_tint
            + 0.008 * planned_environment_reflection
            + 0.006 * planned_environment_color_pickup
            + 0.006 * planned_environment_transmission_balance
            + 0.08 * interactive_tint_field_strength
            + 0.07 * container_pressure_field_strength
            + 0.06 * foreground_sheen_field_strength
            + 0.05 * ambient_chromatic_field_strength
            + 0.06 * environment_sheen_bias,
        0.0,
        0.054);
    if (edge_meniscus_field_strength > 0.0001) {
        float meniscus_edge =
            1.0 - smoothstep(
                0.0,
                max(edge_bevel_width * 2.65, 1.0),
                signed_edge_distance);
        float meniscus_inner =
            1.0 - smoothstep(
                max(edge_bevel_width * 1.15, 0.75),
                max(edge_bevel_width * 4.2, 1.25),
                signed_edge_distance);
        float meniscus_corner =
            smoothstep(0.54, 1.12, normalized_len);
        float meniscus_bridge =
            bridge_band * (0.34 + 0.66 * bridge_core);
        float meniscus_pointer =
            pointer_lens_raw * pointer_lens_strength;
        float meniscus_presence = clamp(
            meniscus_edge * 0.30
                + meniscus_inner * 0.18
                + meniscus_corner * 0.16
                + meniscus_bridge * 0.16
                + meniscus_pointer * 0.12
                + tint_strength * 0.08
                + planned_environment_reflection * 0.10
                + planned_environment_color_pickup * 0.08
                + environment_sheen_bias * 0.08,
            0.0,
            1.0);
        float2 meniscus_axis_raw =
            refraction_dir * (0.32 + 0.22 * glass_lensing_gain)
            - dynamic_light_dir
                * (0.30 + 0.22 * dynamic_light_highlight)
            + pointer_dir * (0.22 + 0.18 * meniscus_pointer)
            + bridge_dir * (0.20 + 0.18 * meniscus_bridge)
            - dynamic_light_dir * (0.08 * planned_environment_reflection)
            + dispersion_tangent
                * (0.16
                   + 0.12 * spectral_dispersion
                   + 0.10 * glass_dispersion_tangential
                   + 0.09 * planned_environment_color_pickup);
        float meniscus_axis_len = length(meniscus_axis_raw);
        float2 meniscus_axis =
            meniscus_axis_len > 0.0001
                ? meniscus_axis_raw / meniscus_axis_len
                : refraction_dir;
        float2 meniscus_cross =
            float2(-meniscus_axis.y, meniscus_axis.x);
        float meniscus_light_face =
            smoothstep(-0.20, 0.94, dot(meniscus_axis, -dynamic_light_dir));
        float meniscus_bridge_alignment =
            smoothstep(-0.24, 0.88, abs(dot(meniscus_axis, bridge_dir)));
        float meniscus_phase = clamp(
            dot(normalized_local, meniscus_axis)
                    * (5.0 + 1.8 * meniscus_presence)
                + dot(normalized_local, meniscus_cross)
                    * (2.6 + 1.0 * meniscus_bridge)
                + bridge_axial * (2.4 + 1.2 * bridge_core)
                + bridge_shear * bridge_band * 1.8
                + materialize_rim_position * materialize_wave_strength * 2.2
                + spectral_dispersion * 4.8
