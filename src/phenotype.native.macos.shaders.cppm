                    * (0.28 + 0.16 * seal_edge),
            float2(0.0),
            float2(1.0));
        float2 seal_return_uv = clamp(
            in.screen_uv
                + refraction_uv * 0.06
                - seal_cross
                    * texel
                    * seal_cross_span
                    * (0.24 + 0.14 * seal_bridge)
                - seal_center_dir
                    * texel
                    * seal_span
