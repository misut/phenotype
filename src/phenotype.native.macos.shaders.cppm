            float2(1.0));
        float2 balance_back_uv = clamp(
            in.screen_uv
                + refraction_uv * 0.24
                - balance_dir
                    * texel
                    * balance_span
                    * (0.38 + 0.18 * balance_rim),
            float2(0.0),
            float2(1.0));
        float2 balance_cross_uv = clamp(
            in.screen_uv
                + refraction_uv * 0.28
                + balance_cross
                    * texel
                    * balance_span
