        float pressure_group_center =
            1.0 - smoothstep(0.18, 1.14, length(pressure_group_norm));
        float pressure_local_center =
            1.0 - smoothstep(0.20, 1.10, normalized_len);
        float pressure_edge =
            1.0 - smoothstep(
