            0.14 * (spectral_warmth + spectral_coolness),
            spectral_coolness);
        flow_layer += flow_prism
            * flow_pickup
            * (0.0008
               + 0.0026 * spectral_rim_tint
               + 0.0026 * glass_prismatic_gain
               + 0.0022 * glass_caustic_spread)
            * (0.30
               + 0.20 * flow_light_face
               + 0.20 * flow_lobe
               + 0.18 * flow_curvature
               + 0.14 * flow_coherence);
        float flow_weight =
            lensing_flow_field_strength
            * flow_gate
            * (0.28
               + 0.18 * flow_coherence
