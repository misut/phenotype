                pocket_dark * (0.18 + 0.18 * glass_shadow_gain));
            pocket_tint = mix(
                pocket_tint,
                pocket_tint * (float3(1.0) + 0.12 * in.tint.rgb),
                clamp(in.tint.a, 0.0, 1.0)
                    * (0.22 + 0.24 * prominent_intensity));
            pocket_tint += float3(
                spectral_warmth,
                0.10 * (spectral_warmth + spectral_coolness),
