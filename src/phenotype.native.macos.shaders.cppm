             + 1.2 * glass_dispersion_tangential
             + 1.2 * spectral_dispersion
             + 0.9 * morph_coupler_transition)
            * content_scale;
        float2 morph_coupler_center_uv = clamp(
            mix(
                in.screen_uv,
                morph_coupler_group_center_uv,
                0.12 + 0.14 * morph_coupler_center),
            float2(0.0),
            float2(1.0));
        float2 morph_coupler_lead_uv = clamp(
            in.screen_uv
                + refraction_uv * 0.20
