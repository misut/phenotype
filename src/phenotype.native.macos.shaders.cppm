                       + sheen_bright * 0.012
                       + sheen_presence * 0.010
                       + planned_environment_reflection * 0.010)
                + float3(0.50),
            0.0,
            1.0);
        sheen_layer *= float3(1.0)
            + in.tint.rgb
                * (0.012
                   + 0.024 * tint_chroma * prominent_intensity
