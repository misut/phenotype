            morph_weight);
        rgb += morph_tint
            * morph_weight
            * (0.018
               + 0.034 * bridge_highlight_gain
               + 0.026 * glass_prismatic_gain);
        rgb += float3(spectral_warmth,
                      0.12 * (spectral_warmth + spectral_coolness),
                      spectral_coolness)
            * morph_weight
            * morph_pinched
            * (0.016 + 0.030 * glass_caustic_spread);
        float morph_shadow = morph_dark
            * morph_field_strength
