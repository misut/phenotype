            float2(1.0));
        float2 morph_coupler_upper_uv = clamp(
            in.screen_uv
                + refraction_uv * 0.15
                + morph_coupler_cross
                    * texel
                    * morph_coupler_cross_span
                    * (0.28 + 0.16 * morph_coupler_edge),
            float2(0.0),
            float2(1.0));
        float2 morph_coupler_lower_uv = clamp(
            in.screen_uv
                + refraction_uv * 0.14
                - morph_coupler_cross
                    * texel
                    * morph_coupler_cross_span
                    * (0.24 + 0.14 * morph_coupler_bridge),
            float2(0.0),
            float2(1.0));
        float3 morph_coupler_center_rgb =
            backdrop.sample(samp, morph_coupler_center_uv).rgb;
        float3 morph_coupler_lead_rgb =
            backdrop.sample(samp, morph_coupler_lead_uv).rgb;
        float3 morph_coupler_return_rgb =
            backdrop.sample(samp, morph_coupler_return_uv).rgb;
        float3 morph_coupler_upper_rgb =
            backdrop.sample(samp, morph_coupler_upper_uv).rgb;
        float3 morph_coupler_lower_rgb =
            backdrop.sample(samp, morph_coupler_lower_uv).rgb;
        float3 morph_coupler_probe =
            morph_coupler_center_rgb * 0.28
            + morph_coupler_lead_rgb * 0.24
            + morph_coupler_return_rgb * 0.20
            + morph_coupler_upper_rgb * 0.15
            + morph_coupler_lower_rgb * 0.13;
        float morph_coupler_luma =
            dot(morph_coupler_probe, float3(0.2126, 0.7152, 0.0722));
        float morph_coupler_surface_luma =
            dot(rgb, float3(0.2126, 0.7152, 0.0722));
        float morph_coupler_range = clamp(
            length(morph_coupler_lead_rgb - morph_coupler_return_rgb) * 0.30
                + length(morph_coupler_upper_rgb - morph_coupler_lower_rgb)
                    * 0.24
                + abs(morph_coupler_luma - morph_coupler_surface_luma)
                    * 0.20
                + morph_coupler_focus * 0.10,
