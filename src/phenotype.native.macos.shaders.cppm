            max(edge_bevel_width * 2.05, 0.5),
            signed_edge_distance);
        float coherence_inner = 1.0 - smoothstep(
            0.0,
            max(edge_width * 0.78, 0.5),
            signed_edge_distance);
        float coherence_meniscus = clamp(
