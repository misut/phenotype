            + bridge_dir * bridge_band * 0.18
            + pointer_dir * pointer_lens * pointer_lens_strength * 0.24;
        float coherence_dir_len = length(coherence_raw_dir);
        float2 coherence_dir = coherence_dir_len > 0.0001
