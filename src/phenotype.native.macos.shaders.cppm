        float diffusion_rim = edge_lens
            * (0.34
               + 0.66
                   * (1.0 - smoothstep(
                       0.0,
                       max(edge_bevel_width * 1.58, 0.5),
                       signed_edge_distance)));
        float diffusion_contact = clamp(
            pointer_lens * pointer_lens_strength
