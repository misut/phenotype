               + 0.0024 * glass_prismatic_gain
               + 0.0020 * glass_scattering_gain)
            * (0.32
               + 0.22 * morph_coupler_coherence
               + 0.24 * morph_coupler_focus
               + 0.22 * morph_coupler_bright);
        float morph_coupler_weight =
