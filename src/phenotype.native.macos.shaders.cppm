        float morph_coupler_edge_distance =
            min(morph_coupler_group_edge.x, morph_coupler_group_edge.y);
        float morph_coupler_edge =
            1.0 - smoothstep(
                0.0,
                max(edge_bevel_width * 2.4, 1.0),
                morph_coupler_edge_distance);
        float morph_coupler_bridge =
            bridge_band * (0.38 + 0.62 * bridge_core);
        float morph_coupler_transition = clamp(
            glass_effect_match_execution * 0.34
                + morph_execution * 0.26
                + materialize_wave_strength * 0.16
                + shape_blend_execution * 0.12
                + union_execution * 0.10
                + morph_field_strength * 1.5
                + thickness_coupler_strength * 1.5,
