{
  "name": "file_explorer_desktop_startup",
  "description": "Startup artifact contract for the Finder-style desktop file explorer example.",
  "expect_platform": "macos",
  "require_frame": true,
  "require_labels": [
    "Toolbar",
    "Sidebar",
    "Status Bar",
    "Finder Window",
    "Locations",
    "Recents",
    "View Controls",
    "Files",
    "Application Form 2.pdf",
    "Screen Recording 2025-11-04.mov",
    "README.txt",
    "Create"
  ],
  "require_roles": [
    "button",
    "material",
    "text_field"
  ],
  "require_material_kinds": [
    "clear",
    "thin",
    "regular",
    "thick"
  ],
  "require_material_surface_roles": [
    "surface",
    "toolbar",
    "sidebar",
    "status_bar",
    "content"
  ],
  "require_material_plans": true,
  "require_material_semantic_runtime_match": true,
  "require_material_plan_summary": {
    "count": 6,
    "fallback": 0,
    "backdrop_sampling": 6,
    "contract_versions": {
      "6": 6
    },
    "roles": {
      "surface": 1,
      "toolbar": 2,
      "sidebar": 1,
      "status_bar": 1,
      "content": 1
    },
    "container_modes": {
      "container": 6
    },
    "container_ids": {
      "2100": 6
    },
    "container_participating": 6,
    "container_unioned": 0,
    "container_interactive": 0,
    "container_morph_transitions": 6
  },
  "require_capabilities": [
    "material_backdrop_blur"
  ],
  "require_runtime_details": [
    {
      "path": "renderer.material_pipeline_ready",
      "equals": true
    },
    {
      "path": "renderer.material_backdrop_source_ready",
      "equals": true
    },
    {
      "path": "renderer.material_executor_summary.material_max_sample_taps",
      "equals": 25
    },
    {
      "path": "renderer.material_executor_summary.material_total_sample_taps",
      "equals": 150
    }
  ],
  "require_material_resource_bounds": {
    "max_plan_blur_radius_lte": 36.0,
    "max_plan_sample_taps_lte": 25,
    "max_budget_blur_radius_lte": 36.0,
    "max_sample_taps_lte": 25,
    "max_pass_count_lte": 1,
    "max_backdrop_pixels_lte": 4000000,
    "max_container_spacing_lte": 16.0,
    "max_container_spacing_gte": 16.0,
    "max_pass_texture_copy_pixels_lte": 4000000,
    "total_plan_sample_taps_lte": 150,
    "total_plan_sample_taps_gte": 150,
    "total_runtime_passes_gte": 1,
    "active_runtime_passes_gte": 1,
    "backdrop_runtime_passes_gte": 1,
    "require_bounded_texture_copy": true,
    "require_deterministic_fallback": true
  },
  "require_material_quality_policy": {
    "require_backdrop_sampling_allowed": true,
    "require_noise_allowed": true,
    "require_shadow_allowed": true,
    "max_blur_radius_lte": 36.0,
    "max_sample_taps_lte": 25,
    "max_backdrop_pixels_lte": 4000000
  }
}
