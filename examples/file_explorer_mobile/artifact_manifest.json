  "expect_platform": "macos",
  "require_frame": true,
  "require_labels": [
    "Toolbar",
    "Locations",
    "Status Bar",
    "Files",
    "Browse",
    "Back",
    "Forward",
    "Trash",
    "Create",
    "Status",
    "[File] README.txt"
  ],
  "require_roles": [
    "button",
    "material",
    "text_field"
  ],
  "require_material_kinds": [
    "clear",
    "thin",
    "regular",
    "thick"
  ],
  "require_material_surface_roles": [
    "surface",
    "toolbar",
    "navigation",
    "status_bar"
  ],
  "require_material_plans": true,
  "require_material_semantic_runtime_match": true,
  "require_material_plan_summary": {
    "count": 22,
    "fallback": 0,
    "backdrop_sampling": 22,
    "contract_versions": {
      "12": 22
