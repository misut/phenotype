    "max_container_spacing_gte": 12.0,
    "max_pass_texture_copy_pixels_lte": 4000000,
    "total_plan_sample_taps_lte": 550,
    "total_plan_sample_taps_gte": 550,
    "total_runtime_passes_gte": 1,
