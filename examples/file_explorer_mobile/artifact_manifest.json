    "roles": {
      "surface": 19,
      "toolbar": 1,
      "navigation": 1,
      "status_bar": 1
    },
    "container_modes": {
      "container": 22
    },
    "container_ids": {
      "3100": 22
    },
    "container_participating": 22,
    "container_unioned": 0,
    "container_interactive": 0,
    "container_morph_transitions": 22,
    "shape_valid": 22,
    "shape_radius_clamped": 0,
    "pass_names": {
      "backdrop-sample-blur": 22
    },
    "pass_executors": {
      "backdrop-filter": 22
    },
    "sampling_kernels": {
      "weighted-5x5-manhattan": 22
    },
    "sampling_weight_profiles": {
      "center4-cardinal2-diagonal1": 22
    },
    "verifier_region_passes": {
      "clear-over-rich-backdrop": "backdrop-sample-blur",
      "thin-balanced-backdrop": "backdrop-sample-blur",
      "regular-legibility-backdrop": "backdrop-sample-blur",
      "thick-high-contrast-backdrop": "backdrop-sample-blur"
    },
    "luminance_curves": {
      "adaptive-backdrop-luma": 22
    }
  },
  "require_capabilities": [
