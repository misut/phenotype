    {
      "path": "renderer.material_executor_summary.material_total_sample_taps",
      "equals": 550
    }
  ],
  "require_runtime_numeric_bounds": [
    {
      "path": "renderer.material_executor_summary.foreground_text_candidate_count",
      "gte": 12,
      "lte": 40
    },
    {
      "path": "renderer.material_executor_summary.foreground_text_remap_count",
      "gte": 10,
      "lte": 40
    }
  ],
  "require_material_resource_bounds": {
    "max_plan_blur_radius_lte": 36.0,
