<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- GameActivity extends AppCompatActivity, so the manifest theme must
         descend from Theme.AppCompat. Full-screen + no action bar mirrors the
         previous Theme.NoTitleBar.Fullscreen intent. -->
    <style name="Theme.Phenotype" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowActionBar">false</item>
        <item name="android:windowFullscreen">true</item>
    </style>

</resources>
