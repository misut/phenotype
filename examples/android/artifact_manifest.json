{
  "name": "android_stage7_startup",
  "description": "Device/emulator artifact contract for the bundled Android stage 7 demo.",
  "expect_platform": "android",
  "require_frame": true,
  "require_labels": [
    "phenotype \u00b7 stage 7",
    "Core Widgets",
    "Android Material Fallback",
    "Stage 7: debug plane + resume + scroll."
  ],
  "require_roles": [
    "button",
    "material"
  ],
  "require_material_kinds": [
    "regular"
  ],
  "require_material_surface_roles": [
    "surface"
  ],
  "require_material_plans": true,
  "require_material_semantic_runtime_match": true,
  "require_material_plan_summary": {
    "count": 1,
    "fallback": 1,
    "backdrop_sampling": 0,
    "fallback_paths": {
      "unsupported-backend": 1
    },
    "fallback_reasons": {
      "backend reports no material backdrop blur support": 1
    },
    "contract_versions": {
      "9": 1
    },
    "roles": {
      "surface": 1
    },
    "container_modes": {
      "isolated": 1
    },
    "container_participating": 0,
    "container_unioned": 0,
    "container_interactive": 0,
    "container_morph_transitions": 0,
    "shape_valid": 1,
    "shape_rounded": 1,
    "shape_radius_clamped": 0,
    "kinds": {
      "regular": 1
    },
    "pass_names": {
      "translucent-rounded-rect": 1
    },
    "pass_executors": {
      "fallback-fill": 1
    },
    "sampling_kernels": {
      "none": 1
    },
    "sampling_weight_profiles": {
      "none": 1
    },
    "luminance_curves": {
      "fallback-flat": 1
    },
    "backdrop_available": 0,
    "backdrop_stable": 0,
    "backdrop_sources": {
      "android-vulkan-fallback": 1
    },
    "luminance_responses": {
      "not-sampled": 1
    },
    "luminance_adapted": 0,
    "render_target_ready": 1,
    "render_target_pixel_formats": {
      "rgba8unorm": 1
    },
    "decision_can_sample_backdrop": 0,
    "decision_backend_supports_backdrop": 0,
    "decision_backdrop_source_ready": 0,
    "decision_reduced_transparency": 0,
    "decision_increase_contrast": 0,
    "decision_reduce_motion": 0,
    "decision_blockers": {
      "unsupported-backend": 1
    },
    "verifier_require_backdrop_source": 0,
    "verifier_require_edge_highlight": 0,
    "verifier_require_container_identity": 0,
    "verifier_require_container_morph_contract": 0,
    "verifier_profiles": {
      "regular-legibility-backdrop": 1
    },
    "verifier_region_layers": {
      "regular-legibility-backdrop": "material-fallback-pass"
    }
  },
  "require_material_resource_bounds": {
    "max_plan_blur_radius_lte": 0.0,
    "max_plan_sample_taps_lte": 0,
    "max_budget_blur_radius_lte": 36.0,
    "max_sample_taps_lte": 25,
    "max_sampling_kernel_radius_lte": 0,
    "max_pass_count_lte": 1,
    "max_backdrop_pixels_lte": 4000000,
    "max_container_spacing_lte": 0,
    "max_pass_texture_copy_pixels_lte": 0,
    "total_pass_texture_copy_pixels_lte": 0,
    "total_runtime_passes_lte": 1,
    "total_runtime_passes_gte": 1,
    "active_runtime_passes_lte": 1,
    "active_runtime_passes_gte": 1,
    "backdrop_runtime_passes_lte": 0,
    "backdrop_runtime_passes_gte": 0,
    "require_bounded_texture_copy": true,
    "require_deterministic_fallback": true
  },
  "require_material_quality_policy": {
    "require_backdrop_sampling_allowed": true,
    "require_noise_allowed": true,
    "require_shadow_allowed": true,
    "max_blur_radius_lte": 36.0,
    "max_sample_taps_lte": 25,
    "max_backdrop_pixels_lte": 4000000
  },
  "require_runtime_details": [
    {
      "path": "renderer.material_pipeline_ready",
      "equals": false
    },
    {
      "path": "renderer.material_backdrop_source_ready",
      "equals": false
    }
  ],
  "require_runtime_numeric_bounds": [
    {
      "path": "renderer.material_executor_summary.plan_count",
      "equals": 1
    },
    {
      "path": "renderer.material_executor_summary.material_instance_count",
      "equals": 0
    },
    {
      "path": "renderer.material_executor_summary.fallback_instance_count",
      "equals": 1
    },
    {
      "path": "renderer.material_executor_summary.material_draw_calls",
      "equals": 0
    },
    {
      "path": "renderer.material_executor_summary.backdrop_copy_count",
      "equals": 0
    },
    {
      "path": "renderer.material_executor_summary.material_upload_bytes",
      "equals": 0
    },
    {
      "path": "renderer.material_executor_summary.cpu_total_ns",
      "gte": 1,
      "lte": 5000000000
    }
  ]
}
