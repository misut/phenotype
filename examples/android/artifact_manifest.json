{
  "name": "android_stage7_startup",
  "description": "Device/emulator artifact contract for the bundled Android stage 7 demo.",
  "expect_platform": "android",
  "require_frame": true,
  "require_labels": [
    "phenotype \u00b7 stage 7",
    "Core Widgets",
    "Android Material Fallback",
    "Stage 7: debug plane + resume + scroll."
  ],
  "require_roles": [
    "button",
    "material"
  ],
  "require_material_kinds": [
    "regular"
  ],
  "require_material_plans": true,
  "require_material_semantic_runtime_match": true,
  "require_material_plan_summary": {
    "count": 1,
    "fallback": 1,
    "backdrop_sampling": 0,
    "fallback_paths": {
      "unsupported-backend": 1
    },
    "kinds": {
      "regular": 1
    },
    "pass_names": {
      "translucent-rounded-rect": 1
    }
  },
  "require_material_resource_bounds": {
    "max_plan_blur_radius_lte": 0.0,
    "max_plan_sample_taps_lte": 0,
    "max_budget_blur_radius_lte": 36.0,
    "max_sample_taps_lte": 25,
    "max_pass_count_lte": 1,
    "max_backdrop_pixels_lte": 10000000,
    "total_runtime_passes_lte": 1,
    "total_runtime_passes_gte": 1,
    "active_runtime_passes_lte": 1,
    "active_runtime_passes_gte": 1,
    "backdrop_runtime_passes_lte": 0,
    "backdrop_runtime_passes_gte": 0,
    "require_bounded_texture_copy": true,
    "require_deterministic_fallback": true
  },
  "require_material_quality_policy": {
    "require_backdrop_sampling_allowed": true,
    "require_noise_allowed": true,
    "require_shadow_allowed": true,
    "max_blur_radius_lte": 36.0,
    "max_sample_taps_lte": 25
  },
  "require_runtime_details": [
    {
      "path": "renderer.material_pipeline_ready",
      "equals": false
    },
    {
      "path": "renderer.material_backdrop_source_ready",
      "equals": false
    }
  ]
}
